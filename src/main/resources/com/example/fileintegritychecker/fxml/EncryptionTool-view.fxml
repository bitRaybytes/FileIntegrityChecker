<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:id="encrGridPane"
          fx:controller="com.example.fileintegritychecker.controller.EncryptionToolController"
          prefHeight="400.0" prefWidth="600.0">
    <Label fx:id="header"/>
    <Label fx:id="subheader"/>
    <TextArea fx:id="encryptText" />
    <Button fx:id="BtnEncryptText"/>
    <Button fx:id="BtncopyToClipboard"/>
    <Label fx:id="encryptionResult"/>

    <ComboBox fx:id="algorithmComboBox"/>



</GridPane>
